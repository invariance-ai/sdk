{
  "name": "@invariance/sdk",
  "version": "0.2.1",
  "description": "Verification infrastructure for AI agents — record, chain, and enforce action receipts",
  "bin": {
    "invariance": "./dist/cli/index.js"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/langchain": {
      "types": "./dist/observability/adapters/langchain.d.ts",
      "import": "./dist/observability/adapters/langchain.js",
      "require": "./dist/observability/adapters/langchain.cjs"
    },
    "./adapters/crewai": {
      "types": "./dist/observability/adapters/crewai.d.ts",
      "import": "./dist/observability/adapters/crewai.js",
      "require": "./dist/observability/adapters/crewai.cjs"
    },
    "./adapters/autogen": {
      "types": "./dist/observability/adapters/autogen.d.ts",
      "import": "./dist/observability/adapters/autogen.js",
      "require": "./dist/observability/adapters/autogen.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude src/__tests__/integration.test.ts",
    "test:integ": "dotenv -e .env.demo -- vitest run src/__tests__/integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "invariance",
    "verification",
    "ai-agent",
    "receipts",
    "hash-chain"
  ],
  "author": "Invariance",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.3",
    "boxen": "^8.0.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.0",
    "commander": "^13.0.0",
    "ora": "^8.0.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hardik-Singh/Invariance.git",
    "directory": "sdk"
  },
  "homepage": "https://invariance.dev",
  "peerDependencies": {
    "langchain": ">=0.1.0",
    "@langchain/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  }
}
