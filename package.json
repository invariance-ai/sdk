{
  "name": "@invariance/sdk",
  "version": "1.0.0",
  "description": "Client SDK for the Invariance platform — instrument agents, manage sessions, query traces, and monitor AI agent behavior",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "import": "./dist/adapters/langchain.js",
      "require": "./dist/adapters/langchain.cjs"
    },
    "./adapters/crewai": {
      "types": "./dist/adapters/crewai.d.ts",
      "import": "./dist/adapters/crewai.js",
      "require": "./dist/adapters/crewai.cjs"
    },
    "./adapters/autogen": {
      "types": "./dist/adapters/autogen.d.ts",
      "import": "./dist/adapters/autogen.js",
      "require": "./dist/adapters/autogen.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm build",
    "test": "vitest run --exclude src/__tests__/integration.test.ts",
    "test:integ": "bash -c 'set -a; source .env.demo; set +a; vitest run src/__tests__/integration.test.ts'",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "invariance",
    "ai-agent",
    "observability",
    "receipts",
    "hash-chain",
    "monitoring",
    "tracing"
  ],
  "author": "Invariance",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.8.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@microsoft/autogen": ">=0.1.0",
    "crewai": ">=0.1.0",
    "langchain": ">=0.1.0",
    "@langchain/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/autogen": {
      "optional": true
    },
    "crewai": {
      "optional": true
    },
    "langchain": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hardik-Singh/invariance-sdk.git"
  },
  "homepage": "https://invariance.dev"
}
